generator client {
	provider = "prisma-client-js"
}

datasource db {
	provider = "postgresql"
	url      = env("DATABASE_URL")
}

enum BattleStatus {
	ACTIVE
	FINISHED
}

enum CardType {
	UNIT
	BUFF
}

enum EffectType {
	GUARD_PASSIVE
	HATCH
	EVOLVE
	BUFF_ATTACK
	BUFF_HEALTH
}

enum TriggerType {
	PASSIVE
	ON_PLAY
	TURN_START_OWNER
	ON_DEATH
}

enum TargetType {
	SELF
	ALLY_UNIT
	ENEMY_UNIT
	ENEMY_HERO
	NONE
}

model Player {
	id               Int      @id @default(autoincrement())
	telegramId       BigInt   @unique
	username         String?
	createdAt        DateTime @default(now())
	updatedAt        DateTime @updatedAt
	deck             Deck?
	battlesAsPlayer1 Battle[] @relation("BattlePlayer1")
	battlesAsPlayer2 Battle[] @relation("BattlePlayer2")
	wonBattles       Battle[] @relation("BattleWinner")
}

model Deck {
	id        Int      @id @default(autoincrement())
	playerId  Int      @unique
	name      String
	cardsJson Json
	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt
	player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Battle {
	id                  Int          @id @default(autoincrement())
	player1Id           Int
	player2Id           Int
	status              BattleStatus @default(ACTIVE)
	winnerId            Int?
	currentTurnPlayerId Int
	battleStateJson     Json
	createdAt           DateTime     @default(now())
	updatedAt           DateTime     @updatedAt
	finishedAt          DateTime?
	player1             Player       @relation("BattlePlayer1", fields: [player1Id], references: [id])
	player2             Player       @relation("BattlePlayer2", fields: [player2Id], references: [id])
	winner              Player?      @relation("BattleWinner", fields: [winnerId], references: [id])

	@@index([player1Id, status])
	@@index([player2Id, status])
}

model CardEffect {
	id Int @id @default(autoincrement())
	cardId Int 
	effectType EffectType
	triggerType TriggerType
	targetType TargetType
	value Int?
	durationEffect Int?
	params Json?
	sortOrder Int @default(0)
	card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

	@@index([cardId, triggerType])
	@@index([effectType])

}

model Card {
	id Int @id @default(autoincrement())
	slug String @unique
	name String
	type CardType
	cost Int
	attack Int?
	health Int?
	species String?
	abilityText String?
	isActive Boolean @default(true)
	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt
	effects CardEffect[] 

	@@index([type, isActive])
}