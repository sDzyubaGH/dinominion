{
	"name": "dinominion-telegram-bot",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tsx src/bot/index.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node dist/src/bot/index.js",
		"test": "node --import tsx --test src/tests/core/engine/*.test.ts",
		"test:watch": "node --import tsx --test --watch src/tests/core/engine/*.test.ts",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prisma:generate": "prisma generate",
		"prisma:migrate": "prisma migrate dev",
		"prisma:seed": "tsx prisma/seed.ts"
	},
	"prisma": {
		"seed": "tsx prisma/seed.ts"
	},
	"dependencies": {
		"@prisma/client": "^6.16.2",
		"dotenv": "^17.3.1",
		"grammy": "^1.41.1",
		"ioredis": "^5.7.0",
		"nodemon": "^3.1.14"
	},
	"devDependencies": {
		"@eslint/js": "^9.34.0",
		"@types/node": "^24.0.0",
		"eslint": "^9.34.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^16.3.0",
		"prettier": "^3.6.2",
		"prisma": "^6.16.2",
		"tsx": "^4.19.4",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.41.0"
	}
}
